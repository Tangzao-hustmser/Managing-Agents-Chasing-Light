# ===========================
# Application
# ===========================
APP_NAME=创新实践基地共享设备和物料管理智能体
APP_ENV=dev

# ===========================
# Database
# ===========================
DATABASE_URL=sqlite:///./smart_lab.db

# ===========================
# Security
# ===========================
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=720

# ===========================
# Qiniu
# ===========================
QINIU_ACCESS_KEY=your_access_key
QINIU_SECRET_KEY=your_secret_key
QINIU_BUCKET=your_bucket_name
QINIU_DOMAIN=https://your-cdn-domain.com
QINIU_UPLOAD_TOKEN_EXPIRE=3600

# ===========================
# LLM
# ===========================
LLM_ENABLED=true
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT=30
